# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# /method artifacts (internal to LP development — not for public repo)
/docs/
/kanban/

# Backups (local skill backups should never reach the repo)
*.bak
*.bak*
*.backup
*.7z

# Sync logs
/tmp/lp-skills-sync.log
/lp-*.png
/.playwright-mcp
/tc*-*.png

# Python compiled files (from skills/ui-ux-pro-max/scripts/)
__pycache__/
*.pyc
/prod-*.png
